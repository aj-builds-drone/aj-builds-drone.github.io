# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
.playwright-mcp/
.serve-root/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — NEVER commit secrets
.env*

# credentials & secrets
**/firebase-cred*.json
**/firebase-service-account*.json
**/*-service-account*.json
**/*.pem
**/*.key

# automation runtime
automation/.venv/
automation/data/
automation/__pycache__/

# docker (secrets live in .env, not in compose)
docker-compose.override.yml

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# upgrade plan (working doc)
UPGRADE_PLAN.md

# empty placeholder dirs
/public/models/

# raw uncompressed video sources (keep only compressed)
public/videos/*-raw.mp4